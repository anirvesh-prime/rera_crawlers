# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Defaults: host=localhost, port=5432, db=rera_crawlers
POSTGRES_USER=
POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=rera_crawlers

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=rera-crawlers-dev

# ── Crawler settings ──────────────────────────────────────────────────────────
# All have defaults in core/config.py — only set here to override.
# DRY_RUN_S3=true          # false in production to actually upload to S3
# CRAWL_ITEM_LIMIT=0       # >0 to cap projects per run (testing)
# MAX_PAGES=               # integer to cap pages per crawler (testing)
# SCRAPE_DETAILS=true      # false to skip detail-page fetches
# LOG_DIR=logs
